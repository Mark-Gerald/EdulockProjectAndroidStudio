<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E2E">

    <!-- Header section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Variable time limits for sessions"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Main content in ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Note text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note: When you open a specific app, EduLock will ask you to set a time limit for using it before access is restricted."
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"
                android:contentDescription="Note"/>

            <!-- Time Limit Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set a Time Limit"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:contentDescription="Set a Time Limit"/>

            <!-- Time Picker Container -->
            <LinearLayout
                android:id="@+id/time_picker_container"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_dark_background"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:contentDescription="Time Picker">
                <!-- NumberPickers will be added here programmatically -->
            </LinearLayout>

            <!-- App Selection Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Apps"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:contentDescription="Select Apps"/>

            <SearchView
                android:id="@+id/search_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:queryHint="Search App"
                android:iconifiedByDefault="false"
                android:background="@drawable/rounded_dark_background"
                android:layout_marginBottom="16dp"
                android:contentDescription="Search App"/>

            <!-- Apps List Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_dark_background"
                android:contentDescription="Apps List">

                <!-- Select All Option -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/select_all_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select All"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:buttonTint="#FFFFFF"
                        android:contentDescription="Select All Checkbox"/>
                </LinearLayout>

                <!-- Apps Container -->
                <LinearLayout
                    android:id="@+id/apps_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:contentDescription="Apps Container">
                    <!-- App items will be added here programmatically -->
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Button Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/cancel_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textAllCaps="true"
            android:layout_marginEnd="8dp"
            android:background="@drawable/cancel_button_background"
            android:padding="12dp"
            android:contentDescription="Cancel Button"/>

        <Button
            android:id="@+id/save_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textAllCaps="true"
            android:background="@drawable/save_button_background"
            android:padding="12dp"
            android:contentDescription="Save Button"/>
    </LinearLayout>

</LinearLayout>