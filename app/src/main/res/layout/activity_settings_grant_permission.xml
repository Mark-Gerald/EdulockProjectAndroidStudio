<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_permission_gradient">

    <!-- PHONE IMAGE -->
    <ImageView
        android:id="@+id/phoneImage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/tutorial_phones"
        android:scaleType="fitCenter"
        android:layout_marginBottom="-40dp"
        app:layout_constraintBottom_toTopOf="@id/bottomCanvas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTTOM CANVAS PANEL -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomCanvas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/background_dark"
        app:strokeWidth="1dp"
        app:strokeColor="#2E2E2E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/accessAppUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Access App Usage Data"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="EduLock requires usage access permission to function effectively. By granting this permission, EduLock can monitor and manage screen time efficiently."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/grantPermissionButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Grant Permission"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                app:cornerRadius="28dp"
                android:background="@drawable/modern_button_bg"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>