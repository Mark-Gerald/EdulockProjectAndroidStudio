<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Control"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Connect this device to a controller to manage focus and screen time."
            android:textColor="@color/restrict_text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"/>

        <!-- QR Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/MudPurple"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/restrict_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

                <!-- Step pill -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_step_pill"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Step 1 of 1"
                    android:textColor="@color/restrict_accent"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.04"
                    android:textAllCaps="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Scan to connect"
                    android:textColor="@color/restrict_text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Open the controller app and point its camera at the code below."
                    android:textColor="@color/restrict_text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"/>

                <!-- QR frame -->
                <FrameLayout
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_qr_frame">

                    <ImageView
                        android:id="@+id/qrCodeImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:padding="18dp"
                        android:contentDescription="QR code"
                        tools:src="@android:drawable/ic_menu_gallery"/>

                    <!-- Empty state placeholder shown when no QR yet -->
                    <LinearLayout
                        android:id="@+id/qrPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:alpha="0.35"
                            android:contentDescription="@null"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Your QR code will appear here"
                            android:textColor="@color/restrict_text_secondary"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- Status chip -->
                <LinearLayout
                    android:id="@+id/statusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_chip_neutral"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot_neutral"/>

                    <TextView
                        android:id="@+id/statusTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Waiting to connect"
                        android:textColor="@color/restrict_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateQrButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="Generate QR code"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/restrict_accent"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:iconPadding="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/disconnectButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Disconnect controller"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconGravity="textStart"
            app:iconPadding="10dp"/>

        <!-- Helper tip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="@drawable/bg_tip">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:src="@android:drawable/ic_dialog_info"
                android:contentDescription="@null"
                app:tint="@color/restrict_accent"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Keep this screen open until the controller confirms the connection. Each code is single-use."
                android:textColor="@color/restrict_text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>