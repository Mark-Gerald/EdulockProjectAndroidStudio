<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3d3841"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Section -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- School Logo and Text Section -->
            <LinearLayout
                android:id="@+id/schoolInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/schoolLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/lagro_high_school_logo" />

                <LinearLayout
                    android:id="@+id/schoolText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/schoolName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAGRO"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/trends"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/highSchoolText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="HIGH"
                        android:fontFamily="@font/trends"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/schoolTextSuffix"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:text="SCHOOL"
                        android:fontFamily="@font/trends"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Vertical Bar -->
                <TextView
                    android:id="@+id/verticalBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_gravity="center_vertical"
                    android:text="|"
                    android:fontFamily="@font/trends"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp" />

                <!-- EduLock Text -->
                <TextView
                    android:id="@+id/eduLockText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_gravity="center_vertical"
                    android:text="EduLock"
                    android:fontFamily="@font/trends"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sign Up Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/headerSection"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:cardBackgroundColor="#2A2731"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/signUpLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/linear_layout_stroke"
                android:padding="24dp">

                <TextView
                    android:id="@+id/signUpTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/signUpSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Create your account"
                    android:textAlignment="center"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/signup_firstname"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/custom_edittext"
                    android:backgroundTint="#3a3440"
                    android:drawableLeft="@drawable/baseline_alternate_email_24"
                    android:hint=" First Name"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textColorHint="#676767" />
                <EditText
                    android:id="@+id/signup_lastname"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/custom_edittext"
                    android:backgroundTint="#3a3440"
                    android:drawableLeft="@drawable/baseline_alternate_email_24"
                    android:hint=" Last Name"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textColorHint="#676767" />

                <EditText
                    android:id="@+id/signup_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/custom_edittext"
                    android:backgroundTint="#3a3440"
                    android:drawableLeft="@drawable/baseline_email_address_24"
                    android:hint=" Email Address"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textColorHint="#676767" />

                <EditText
                    android:id="@+id/signup_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/custom_edittext"
                    android:backgroundTint="#3a3440"
                    android:drawableLeft="@drawable/baseline_lock_24"
                    android:hint=" Password"
                    android:inputType="textPassword"
                    android:padding="4dp"
                    android:textColor="@color/white"
                    android:textColorHint="#676767" />

                <RadioGroup
                    android:id="@+id/radioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="24dp"/>

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teacher"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="24dp"/>
                </RadioGroup>

                <Button
                    android:id="@+id/signup_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:theme="@style/CustomButtonStyle"
                    android:padding="12dp"
                    android:text="Sign Up"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp" />

                <LinearLayout
                    android:id="@+id/loginLinkArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/alreadyHaveAccountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textColor="#9E9E9E" />

                    <TextView
                        android:id="@+id/loginRedirectText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login"
                        android:textColor="#6200EE" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
