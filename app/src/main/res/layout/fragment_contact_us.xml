<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mud">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Contact Form Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/contact_form_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/MudPurple">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Us"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/editTextName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Username"
                    android:textColorHint="@color/white"
                    android:textColor="@color/white"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editTextEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:textColorHint="@color/white"
                    android:textColor="@color/white"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editTextPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone"
                    android:inputType="phone"
                    android:textColorHint="@color/white"
                    android:textColor="@color/white"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editTextMessage"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Message"
                    android:gravity="top"
                    android:textColorHint="@color/white"
                    android:textColor="@color/white"
                    android:background="@drawable/edit_text_background"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/buttonSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submit"
                    android:backgroundTint="@color/DarkerViolet"
                    android:textColor="@color/white"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_alignEnd="@id/contact_form_card"
            android:layout_alignBottom="@id/contact_form_card"
            android:src="@drawable/contact_us_first"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="10dp"
            android:elevation="4dp"/>

        <!-- Contact Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/contact_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/contact_form_card"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/LightViolet">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EduLock's Media"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P2GB+PD3, Misa de Gallo, Novaliches, Quezon City, Metro Manila"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_location"
                    android:drawablePadding="8dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="123-456-7891"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="8dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="edulock25@gmail.com"
                    android:textColor="@color/black"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_alignEnd="@id/contact_info_card"
            android:layout_alignBottom="@id/contact_info_card"
            android:src="@drawable/contact_us_second"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="-2dp"
            android:elevation="4dp"/>
    </RelativeLayout>
</ScrollView>