<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Remove Material Button Overlay -->
        <item name="buttonStyle">@style/Widget.AppCompat.Button</item>
        <item name="colorPrimary">@color/mud</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/mud</item>
    </style>

    <!-- Custom theme that inherits AppTheme -->
    <style name="Theme.EduLock" parent="AppTheme" />

    <style name="Theme.EduLock.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ThemeOverlay.AppCompat.navTheme">
        <item name="colorPrimary">@color/white</item>
    </style>

    <style name="Theme.EduLock.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.EduLock.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="CustomButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/MudPurple</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">15dp</item>
    </style>

    <style name="FullScreenDialogStyle" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/mud</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Consistent dialog theme regardless of device/dark mode -->
    <style name="EduLock.AlertDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:background">#2D2D2D</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
        <item name="buttonBarPositiveButtonStyle">@style/EduLock.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/EduLock.DialogButton.Negative</item>
    </style>

    <style name="EduLock.DialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#BB86FC</item>   <!-- purple accent -->
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EduLock.DialogButton.Negative">
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>
